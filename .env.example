# OpenAI API Key (obrigatório para análise)
OPENAI_API_KEY=sk-your-key-here

# Credenciais do Instagram (opcional, mas pode ser necessário)
# O Instagram pode exigir login mesmo para posts públicos.
# MÉTODOS DE LOGIN:
# Opção A (Menos segura, sujeita a bloqueios):
IG_USERNAME=
IG_PASSWORD=

# Opção B (Mais segura, não dá erro de login):
# Pegue o valor do cookie "sessionid" no seu navegador logado no Instagram
IG_SESSIONID=
